# ── Reloop configuration ──────────────────────────────────────────────
# Copy to .env.local and fill in. The app runs fully WITHOUT any keys
# (RELOOP_AI_MODE=mock is the default), so you can demo before adding keys.

# AI mode: "mock" (no key needed, default) or "live" (calls OpenAI)
RELOOP_AI_MODE=mock

# OpenAI API key — only needed when RELOOP_AI_MODE=live.
# Get it at https://platform.openai.com/api-keys (starts with "sk-...").
OPENAI_API_KEY=

# Optional model overrides (sensible defaults are used if unset).
# Default is gpt-5.4-mini everywhere: multimodal (vision) + structured outputs
# + web_search, ~3x cheaper than gpt-5.4. Bump the scan to the full model if a
# real photo is ever misidentified on stage.
# RELOOP_SCAN_MODEL=gpt-5.4
# RELOOP_REPAIR_MODEL=gpt-5.4-mini
# RELOOP_RESALE_MODEL=gpt-5.4-mini

# Public base URL (for deep links / PWA). Safe to expose.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional affiliate/referral IDs (deep links work without them).
AFFILIATE_VINTED_ID=
AFFILIATE_BACKMARKET_ID=
