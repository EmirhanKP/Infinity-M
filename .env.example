# ── Reloop configuration ──────────────────────────────────────────────
# Copy to .env.local and fill in. The app runs fully WITHOUT any keys
# (RELOOP_AI_MODE=mock is the default), so you can demo before adding keys.

# AI mode: "mock" (no key needed, default) or "live" (calls Claude)
RELOOP_AI_MODE=mock

# Anthropic Claude API key — only needed when RELOOP_AI_MODE=live.
# Drop your key in here later, then set RELOOP_AI_MODE=live.
ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults are used if unset).
# Scan needs a vision model with structured output. Fable 5 requires 30-day
# data retention; if your org/key can't use it, switch to claude-opus-4-8.
# RELOOP_SCAN_MODEL=claude-fable-5
# RELOOP_REPAIR_MODEL=claude-haiku-4-5
# RELOOP_RESALE_MODEL=claude-fable-5

# Public base URL (for deep links / PWA). Safe to expose.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional affiliate/referral IDs (deep links work without them).
AFFILIATE_VINTED_ID=
AFFILIATE_BACKMARKET_ID=
